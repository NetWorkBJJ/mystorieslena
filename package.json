{
  "name": "mystorieslena",
  "productName": "MyStoriesLena",
  "version": "1.0.39",
  "description": "MyStoriesLena — Gerador de Roteiros de Romance",
  "private": true,
  "main": "electron/main.js",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "electron:dev": "concurrently -k \"npm:dev\" \"wait-on http://localhost:3000 && cross-env NEXT_DEV_URL=http://localhost:3000 electron .\"",
    "electron:start": "electron .",
    "prepackage": "node scripts/build-icon.js",
    "package": "next build && electron-builder --win nsis",
    "package:dir": "next build && electron-builder --dir",
    "release": "next build && electron-builder --win nsis --publish always",
    "release:draft": "next build && electron-builder --win nsis --publish onTagOrDraft",
    "icon:build": "node scripts/build-icon.js"
  },
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "^0.2.119",
    "@anthropic-ai/claude-code": "^2.0.0",
    "@tailwindcss/typography": "^0.5.19",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "electron-log": "^5.4.3",
    "electron-updater": "^6.3.9",
    "lucide-react": "^1.11.0",
    "next": "16.2.4",
    "radix-ui": "^1.4.3",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-markdown": "^10.1.0",
    "remark-gfm": "^4.0.1",
    "shadcn": "^4.4.0",
    "tailwind-merge": "^3.5.0",
    "tw-animate-css": "^1.4.0",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "concurrently": "^9.0.1",
    "cross-env": "^7.0.3",
    "electron": "^33.0.0",
    "electron-builder": "^25.1.8",
    "png-to-ico": "^2.1.8",
    "sharp": "^0.34.0",
    "tailwindcss": "^4",
    "typescript": "^5",
    "wait-on": "^8.0.1"
  },
  "build": {
    "appId": "com.mystorieslena.app",
    "productName": "MyStoriesLena",
    "afterPack": "scripts/mac-adhoc-sign.js",
    "directories": {
      "output": "dist-electron"
    },
    "files": [
      "electron/**/*",
      "!electron/dist/**",
      "!electron/icons/source.svg"
    ],
    "extraResources": [
      {
        "from": ".next/standalone",
        "to": "app",
        "filter": [
          "**/*",
          "!node_modules/@anthropic-ai/**"
        ]
      },
      {
        "from": ".next/static",
        "to": "app/.next/static",
        "filter": [
          "**/*"
        ]
      },
      {
        "from": "node_modules/@anthropic-ai",
        "to": "app/node_modules/@anthropic-ai",
        "filter": [
          "claude-code-*/**/*",
          "claude-agent-sdk-*/**/*"
        ]
      }
    ],
    "publish": [
      {
        "provider": "github",
        "owner": "lucasbaziliocomercial-crypto",
        "repo": "mystorieslena",
        "releaseType": "release"
      }
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "electron/icons/icon.ico",
      "artifactName": "MyStoriesLena-Setup-${version}.${ext}"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "MyStoriesLena",
      "installerIcon": "electron/icons/icon.ico",
      "uninstallerIcon": "electron/icons/icon.ico"
    },
    "mac": {
      "target": [
        {
          "target": "dmg",
          "arch": [
            "arm64",
            "x64"
          ]
        },
        {
          "target": "zip",
          "arch": [
            "arm64",
            "x64"
          ]
        }
      ],
      "icon": "electron/icons/icon.png",
      "category": "public.app-category.productivity",
      "artifactName": "MyStoriesLena-${version}-${arch}.${ext}",
      "hardenedRuntime": false,
      "gatekeeperAssess": false,
      "identity": null
    },
    "dmg": {
      "title": "MyStoriesLena ${version}",
      "icon": "electron/icons/icon.png",
      "contents": [
        {
          "x": 130,
          "y": 220
        },
        {
          "x": 410,
          "y": 220,
          "type": "link",
          "path": "/Applications"
        }
      ],
      "window": {
        "width": 540,
        "height": 380
      }
    }
  }
}
